# ── Pioneer AI ──────────────────────────────────────────────────────────────
# API key for the external analysis provider
PIONEER_API_KEY=

# Chat completions endpoint
PIONEER_ENDPOINT=https://api.pioneer.ai/v1/chat/completions

# Provider-specific model identifier
PIONEER_MODEL=pioneer-fast

# Token budget per AI request
PIONEER_MAX_TOKENS=1500

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
PIONEER_TEMPERATURE=0.2

# ── AI Behaviour ────────────────────────────────────────────────────────────
# Enable AI-powered analysis and remediation (true/false)
AI_ENABLED=true

# Minimum severity to trigger AI analysis (Low | Medium | High | Critical)
AI_MIN_SEVERITY=Medium

# Maximum AI calls allowed per scan cycle
AI_RATE_LIMIT_PER_SCAN=5

# HTTP timeout for AI requests in seconds
AI_TIMEOUT_SECONDS=30

# ── Scanning ────────────────────────────────────────────────────────────────
# How often the agent scans the cluster (seconds)
SCAN_INTERVAL_SECONDS=120

# Maximum log lines to fetch per pod per scan
LOG_LINE_LIMIT=150

# ── Cluster ─────────────────────────────────────────────────────────────────
# Human-readable cluster label shown in the dashboard
CLUSTER_NAME=local-cluster

# kubectl context name to use (leave empty for active context / in-cluster)
KUBE_CONTEXT=

# ── Storage ─────────────────────────────────────────────────────────────────
# SQLite database path. In Kubernetes, mount a PersistentVolume at /data.
STORAGE_PATH=/data/ai-kube-agent.sqlite3

# ── Demo ────────────────────────────────────────────────────────────────────
# Secret token required to call POST /api/demo/reset.
# Leave empty to disable the demo reset endpoint entirely.
DEMO_RESET_TOKEN=
